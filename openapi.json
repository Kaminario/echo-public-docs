  "components": {
    "schemas": {
      "Cloud": {
        "type": "string",
        "enum": [
          "GCP",
          "AWS",
          "AZURE",
          "UNKNOWN"
        ],
        "title": "Cloud"
      },
      "CommandKind": {
        "type": "string",
        "enum": [
          "CreateCloneCommand",
          "CreateExtractCommand",
          "ImportExtractCommand"
        ],
        "title": "CommandKind"
      },
      "CreateCloneRequest": {
        "properties": {
          "database_id": {
            "type": "string",
            "title": "Database Id"
          },
          "source_host_id": {
            "type": "string",
            "title": "Source Host Id"
          },
          "destination_host_ids": {
            "items": {
              "type": "string"
            },
            "type": "array",
            "title": "Destination Host Ids"
          }
        },
        "type": "object",
        "required": [
          "database_id",
          "source_host_id",
          "destination_host_ids"
        ],
        "title": "CreateCloneRequest"
      },
      "CreateExtractRequest": {
        "properties": {
          "database_id": {
            "type": "string",
            "title": "Database Id"
          },
          "source_host_id": {
            "type": "string",
            "title": "Source Host Id"
          }
        },
        "type": "object",
        "required": [
          "database_id",
          "source_host_id"
        ],
        "title": "CreateExtractRequest"
      },
      "CreateHostResponse": {
        "properties": {
          "host_id": {
            "type": "string",
            "title": "Host Id"
          },
          "db_vendor": {
            "$ref": "#/components/schemas/DBVendor"
          },
          "token": {
            "type": "string",
            "title": "Token"
          }
        },
        "type": "object",
        "required": [
          "host_id",
          "db_vendor",
          "token"
        ],
        "title": "CreateHostResponse"
      },
      "DBVendor": {
        "type": "string",
        "enum": [
          "mssql"
        ],
        "const": "mssql",
        "title": "DBVendor"
      },
      "HTTPValidationError": {
        "properties": {
          "detail": {
            "items": {
              "$ref": "#/components/schemas/ValidationError"
            },
            "type": "array",
            "title": "Detail"
          }
        },
        "type": "object",
        "title": "HTTPValidationError"
      },
      "Host": {
        "properties": {
          "host_id": {
            "type": "string",
            "title": "Host Id"
          },
          "db_vendor": {
            "allOf": [
              {
                "$ref": "#/components/schemas/DBVendor"
              }
            ],
            "default": "mssql"
          },
          "last_seen_ts": {
            "type": "integer",
            "title": "Last Seen Ts",
            "default": 0
          },
          "host_name": {
            "type": "string",
            "title": "Host Name",
            "default": ""
          },
          "host_iqn": {
            "type": "string",
            "title": "Host Iqn",
            "default": ""
          },
          "host_os": {
            "type": "string",
            "title": "Host Os",
            "default": ""
          },
          "host_os_version": {
            "type": "string",
            "title": "Host Os Version",
            "default": ""
          },
          "agent_version": {
            "type": "string",
            "title": "Agent Version",
            "default": ""
          },
          "cloud_vendor": {
            "anyOf": [
              {
                "$ref": "#/components/schemas/Cloud"
              },
              {
                "type": "null"
              }
            ],
            "default": "UNKNOWN"
          }
        },
        "type": "object",
        "required": [
          "host_id"
        ],
        "title": "Host"
      },
      "ImportExtractRequest": {
        "properties": {
          "extract_id": {
            "type": "string",
            "title": "Extract Id"
          },
          "destination_host_ids": {
            "items": {
              "type": "string"
            },
            "type": "array",
            "title": "Destination Host Ids"
          }
        },
        "type": "object",
        "required": [
          "extract_id",
          "destination_host_ids"
        ],
        "title": "ImportExtractRequest"
      },
      "TaskState": {
        "type": "string",
        "enum": [
          "running",
          "completed",
          "failed",
          "aborted"
        ],
        "title": "TaskState"
      },
      "TaskStatusResponse": {
        "properties": {
          "state": {
            "$ref": "#/components/schemas/TaskState"
          },
          "create_ts": {
            "type": "integer",
            "title": "Create Ts"
          },
          "update_ts": {
            "type": "integer",
            "title": "Update Ts"
          },
          "request_id": {
            "type": "string",
            "title": "Request Id"
          },
          "owner": {
            "type": "string",
            "title": "Owner"
          },
          "command_type": {
            "$ref": "#/components/schemas/CommandKind"
          },
          "ref_id": {
            "type": "string",
            "title": "Ref Id"
          },
          "error": {
            "type": "string",
            "title": "Error",
            "default": ""
          },
          "location": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Location"
          }
        },
        "type": "object",
        "required": [
          "state",
          "create_ts",
          "update_ts",
          "request_id",
          "owner",
          "command_type",
          "ref_id"
        ],
        "title": "TaskStatusResponse"
      },
      "ValidationError": {
        "properties": {
          "loc": {
            "items": {
              "anyOf": [
                {
                  "type": "string"
                },
                {
                  "type": "integer"
                }
              ]
            },
            "type": "array",
            "title": "Location"
          },
          "msg": {
            "type": "string",
            "title": "Message"
          },
          "type": {
            "type": "string",
            "title": "Error Type"
          }
        },
        "type": "object",
        "required": [
          "loc",
          "msg",
          "type"
        ],
        "title": "ValidationError"
      }
    },
    "securitySchemes": {
      "HTTPBearer": {
        "type": "http",
        "scheme": "bearer"
      }
    }
  }
}
