{
  "openapi": "3.1.0",
  "info": {
    "title": "silk-server",
    "description": "Silk Instant Extract Server Imitation",
    "version": "0.1.0"
  },
  "paths": {
    "/flex/api/v1/hosts/{host_id}": {
      "put": {
        "tags": [
          "hosts"
        ],
        "summary": "Register Host",
        "description": "Register a new host",
        "operationId": "register_host_flex_api_v1_hosts__host_id__put",
        "security": [
          {
            "HTTPBearer": []
          }
        ],
        "parameters": [
          {
            "name": "host_id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string",
              "minLength": 3,
              "maxLength": 32,
              "pattern": "^[a-zA-Z][a-zA-Z0-9_-]+[a-zA-Z0-9]$",
              "description": "The ID of the host. Must start with letter, end with letter or number. Only letters, numbers, underscore and hyphen are allowed. Min length 3, max length 32",
              "title": "Host Id"
            },
            "description": "The ID of the host. Must start with letter, end with letter or number. Only letters, numbers, underscore and hyphen are allowed. Min length 3, max length 32"
          },
          {
            "name": "dbvendor",
            "in": "query",
            "required": false,
            "schema": {
              "allOf": [
                {
                  "$ref": "#/components/schemas/DBVendor"
                }
              ],
              "default": "mssql",
              "title": "Dbvendor"
            }
          },
          {
            "name": "hs-ref-id",
            "in": "header",
            "required": false,
            "schema": {
              "type": "string",
              "title": "Hs-Ref-Id"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/CreateHostResponse"
                }
              }
            }
          },
          "409": {
            "description": "Host already exists"
          },
          "422": {
            "description": "Validation Error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            }
          }
        }
      },
      "delete": {
        "tags": [
          "hosts"
        ],
        "summary": "Unregister",
        "description": "Unregister a host",
        "operationId": "unregister_flex_api_v1_hosts__host_id__delete",
        "security": [
          {
            "HTTPBearer": []
          }
        ],
        "parameters": [
          {
            "name": "host_id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string",
              "minLength": 3,
              "maxLength": 32,
              "pattern": "^[a-zA-Z][a-zA-Z0-9_-]+[a-zA-Z0-9]$",
              "description": "The ID of the host. Must start with letter, end with letter or number. Only letters, numbers, underscore and hyphen are allowed. Min length 3, max length 32",
              "title": "Host Id"
            },
            "description": "The ID of the host. Must start with letter, end with letter or number. Only letters, numbers, underscore and hyphen are allowed. Min length 3, max length 32"
          },
          {
            "name": "hs-ref-id",
            "in": "header",
            "required": false,
            "schema": {
              "type": "string",
              "title": "Hs-Ref-Id"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {}
              }
            }
          },
          "422": {
            "description": "Validation Error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            }
          }
        }
      },
      "get": {
        "tags": [
          "hosts"
        ],
        "summary": "Get Host",
        "description": "get host information",
        "operationId": "get_host_flex_api_v1_hosts__host_id__get",
        "security": [
          {
            "HTTPBearer": []
          }
        ],
        "parameters": [
          {
            "name": "host_id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string",
              "minLength": 3,
              "maxLength": 32,
              "pattern": "^[a-zA-Z][a-zA-Z0-9_-]+[a-zA-Z0-9]$",
              "description": "The ID of the host. Must start with letter, end with letter or number. Only letters, numbers, underscore and hyphen are allowed. Min length 3, max length 32",
              "title": "Host Id"
            },
            "description": "The ID of the host. Must start with letter, end with letter or number. Only letters, numbers, underscore and hyphen are allowed. Min length 3, max length 32"
          },
          {
            "name": "hs-ref-id",
            "in": "header",
            "required": false,
            "schema": {
              "type": "string",
              "title": "Hs-Ref-Id"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Host"
                }
              }
            }
          },
          "422": {
            "description": "Validation Error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            }
          }
        }
      }
    },
    "/flex/api/v1/hosts": {
      "get": {
        "tags": [
