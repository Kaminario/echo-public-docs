    "/flex/api/v1/extract/tasks/{request_id}": {
      "get": {
        "tags": [
          "status"
        ],
        "summary": "Get Task",
        "operationId": "get_task_flex_api_v1_extract_tasks__request_id__get",
        "security": [
          {
            "HTTPBearer": []
          }
        ],
        "parameters": [
          {
            "name": "request_id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string",
              "title": "Request Id"
            }
          },
          {
            "name": "hs-ref-id",
            "in": "header",
            "required": false,
            "schema": {
              "type": "string",
